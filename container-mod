# --- Script Configuration ---
VERSION="1.1.2"
PROGNAME="$(basename "$0")"
E_OK=0
CONTAINER_APPS="singularity apptainer"
CONTAINER_RUNTIME=""
CONTAINER_RUNTIME_FLAVOR=""
CONTAINER_MODULE_NAME=""
MODULE_SYSTEM="lmod"

###############################################################################
#  PREREQUISITE CHECK
#  Ensures that a container runtime (Singularity or Apptainer) is available.
###############################################################################

detect_container_runtime() {
    # Prefer the module-provided runtime when one is available, even
    # when an OS-installed binary already lives in PATH.  Sites like
    # Tufts ship Apptainer both as a system package (in /usr/bin) and
    # as an Lmod module; the module is the admin-curated version that
    # the rest of the cluster expects, so we want generated modules
    # and wrappers to use it consistently rather than whatever the
    # package manager dropped on disk.
    #
    # Fallback chain:
    #   1. module load singularity  (if a module by that name exists)
    #   2. module load apptainer    (if a module by that name exists)
    #   3. singularity in PATH      (system binary)
    #   4. apptainer in PATH        (system binary)
    #   5. error
    # Make sure the `module` function is reachable from this subshell
    # before we ask it about availability or loading.  Without this,
    # Lmod's init-script-defined `module` function is invisible here.
    if ensure_module_function && type module &>/dev/null; then
        for container_app in ${CONTAINER_APPS}
        do
            if module_is_available "${container_app}"; then
                if module load ${container_app} &>/dev/null && command -v ${container_app} &>/dev/null; then
                    CONTAINER_RUNTIME="${container_app}"
                    CONTAINER_RUNTIME_FLAVOR="$(runtime_flavor_for_command "${container_app}")"
                    CONTAINER_MODULE_NAME="${container_app}"
                    return 0
                fi
            fi
        done
    fi

    # Fall back to system binaries when no module-provided runtime
    # is available (Monishnd-style site with apptainer in /usr/bin
    # and no Lmod entry, or any host without Lmod at all).
    for container_app in ${CONTAINER_APPS}
    do
        if command -v "${container_app}" &>/dev/null; then
            CONTAINER_RUNTIME="${container_app}"
            CONTAINER_RUNTIME_FLAVOR="$(runtime_flavor_for_command "${container_app}")"
            CONTAINER_MODULE_NAME="${container_app}"
            return 0
        fi
    done

    warn -p "Error: Failed to find or load a container runtime ($(echo "${CONTAINER_APPS}" | sed 's/ /\//g'))."
    return 1
}

