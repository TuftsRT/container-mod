#!/bin/bash

set -uo pipefail

# Force a permissive umask so default-created files end up 644 and
# directories 755, regardless of the admin's shell umask.  Every
# explicit chmod in the script reinforces this; the umask covers the
# brief window between creation and the chmod, and any path we forget
# to chmod (mktemp temp files, intermediate parents created by mkdir -p,
# etc.).  Admins running with umask 077 would otherwise produce a tree
# where users can read the leaf wrapper but cannot traverse the parent
# directory to reach it.
umask 022

