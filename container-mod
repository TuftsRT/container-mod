# Lists available configuration profiles.
list_profiles() {
    if [ -d "${PROFILEHOMEDIR}" ];
    then
        for PROFILE in "${PROFILEHOMEDIR}"/*;
        do
            PROFILENAME="$(basename "${PROFILE}")"
            if [ "${PROFILENAME}" != "*" ];
            then
                echo "${PROFILENAME}  (Personal Profile)"
            fi
        done
    fi
    if [ -d "${PROFILEROOT}" ];
    then
        for PROFILE in "${PROFILEROOT}"/*;
        do
            PROFILENAME="$(basename "${PROFILE}")"
            if [ "${PROFILENAME}" != "*" ];
            then
                if [ -e "${PROFILEHOMEDIR}/${PROFILENAME}" ];
                then
                    echo "${PROFILENAME}  (Overridden)"
                else
                    echo "${PROFILENAME}"
                fi
            fi
        done
    fi
    exit 0
}

# Displays a message inside a formatted text box.
# @param $@ - The lines of text to display.
boxify_text() {
	local msg=("$@")
	local line longest width=0
	for line in "${msg[@]}"; do
		if [[ ${#line} -gt $width ]];
		then
			longest="$line"
			width="${#line}"
		fi
	done
	echo "+-${longest//?/-}-+"
	for line in "${msg[@]}"; do
		printf '| %s%*s%s |\n' "$(tput bold)" "-$width" "$line" "$(tput sgr0)"
	done
	echo "+-${longest//?/-}-+"
}

# Creates a directory if it doesn't exist and sets its permissions to 755.
# @param $1 - The path to the directory to create.
# @param $2 - A message to display upon creation.
create_dir() {
    local dir_path="$1"
    local message="$2"
    if [[ ! -d "$dir_path" ]]; then
        mkdir -p -m 755 "$dir_path"
        echo "$message: $dir_path"
    else
        chmod 755 "$dir_path"
    fi
}

ensure_dir_access() {
    local dir_path="$1"
    mkdir -p "$dir_path" || return 1
    # mkdir -p may have created several intermediate parents using the
    # process umask; walk the chain so every newly-created directory is
    # traversable by users (755).  We stop at $HOME or / so we never
    # touch directories outside what container-mod owns.
    local p="$dir_path"
    while [[ -n "$p" && "$p" != "/" && "$p" != "$HOME" && "$p" != "." ]]; do
        chmod 755 "$p" 2>/dev/null || break
        p="$(dirname "$p")"
    done
    return 0
}

ensure_tree_access() {
    local root_path="$1"
    local file_mode="$2"

    [[ -e "$root_path" ]] || return 0

    if [[ -d "$root_path" ]]; then
        find "$root_path" -type d -exec chmod 755 {} +
        find "$root_path" -type f -exec chmod "$file_mode" {} +
    else
        chmod "$file_mode" "$root_path"
    fi
}

get_mtime() {
    local file_path="$1"
    if stat -c %Y "$file_path" &>/dev/null; then
        stat -c %Y "$file_path"
    else
        stat -f %m "$file_path"
    fi
}

# Returns the file mode in octal (e.g. "755") in a portable way.
# @param $1 - The file path.
get_mode() {
    local file_path="$1"
    if stat -c %a "$file_path" &>/dev/null; then
        stat -c %a "$file_path"
    else
        stat -f %Mp%Lp "$file_path" 2>/dev/null | tail -c 4 | sed 's/^0*//'
    fi
}

# Lmod and Environment Modules define `module` as a shell function
# in /etc/profile.d/*.sh, NOT as a regular executable.  Shell
# functions are not inherited by child processes by default, so when
# container-mod starts as a subprocess of an interactive login shell
# the function is missing and every `module ...` invocation fails.
# We re-source the well-known init scripts (or fall back to LMOD_CMD
# directly) so the function is available inside the script.
ensure_module_function() {
    if type module &>/dev/null; then
        return 0
    fi
    local init
    for init in \
        "${LMOD_PKG:-}/init/bash" \
        "${MODULESHOME:-}/init/bash" \
        /etc/profile.d/lmod.sh \
        /etc/profile.d/z00_lmod.sh \
        /etc/profile.d/00-modulepath.sh \
        /etc/profile.d/modules.sh; do
        [[ -z "$init" || ! -f "$init" ]] && continue
        # shellcheck disable=SC1090
        source "$init" 2>/dev/null
        if type module &>/dev/null; then
            return 0
        fi
    done
    # Synthesize a `module` function that calls LMOD_CMD directly.
    # LMOD_CMD is exported by Lmod's init script and IS inherited by
    # subprocesses, so this works even when the function form isn't.
    if [[ -n "${LMOD_CMD:-}" && -x "${LMOD_CMD:-}" ]]; then
        module() { eval "$("$LMOD_CMD" bash "$@")"; }
        return 0
    fi
    return 1
}

# Returns 0 if a Lmod / Environment Modules entry by the given name is
# loadable on this system.  Used to decide whether the generated
# modulefile should contain a `depends_on(...)` line.
#
# Some sites have the container runtime available only as a system
# binary (e.g. Apptainer installed via the package manager, with a
# `singularity` alias), with no corresponding entry in the module
# tree.  Without this check, the generated modulefile would
# `depends_on("singularity")` and `module load <app>` would fail with
# "module(s) are unknown: singularity".
#
# This check is intentionally permissive - the failure mode of
# falsely thinking a module exists is one missing module load at
# runtime; falsely thinking it doesn't exist is a generated
# modulefile that simply doesn't auto-load the runtime.  Both are
# easily recoverable, while the previous behavior (always emit
# depends_on) was a hard failure on systems without the module.
#
# @param $1 - The module name to check.
# @return 0 if available, 1 otherwise.
module_is_available() {
    local mod="$1"
    [[ -z "$mod" ]] && return 1
    ensure_module_function || return 1
    if ! type module &>/dev/null; then
        return 1
    fi
    # `module avail` writes its listing to stderr; redirect both.
    module avail "$mod" 2>&1 | grep -qw -- "$mod"
}

# Verifies a path tree has the expected modes for a shared admin
# deployment: 755 on every directory, $1 on every file.  Prints a
# warning for each mismatch but does not abort.  Designed to be cheap
# enough to run at the end of every subcommand so an admin sees any
# permission drift immediately.
# @param $1 - Root path to verify.
# @param $2 - Expected file mode (e.g. 644, 755).
# @param $3 - Optional label for log output.
verify_tree_perms() {
    local root_path="$1"
    local expected_file_mode="$2"
    local label="${3:-tree}"
    [[ -e "$root_path" ]] || return 0

    local mismatches=0 path actual
    while IFS= read -r path; do
        actual=$(get_mode "$path")
        if [[ -d "$path" ]]; then
            if [[ "$actual" != "755" ]]; then
                warn -p "Permission warning: dir $path is $actual (expected 755)"
                mismatches=$((mismatches + 1))
            fi
        elif [[ -f "$path" ]]; then
            if [[ "$actual" != "$expected_file_mode" ]]; then
                warn -p "Permission warning: file $path is $actual (expected $expected_file_mode)"
                mismatches=$((mismatches + 1))
            fi
        fi
    done < <(find "$root_path" \( -type d -o -type f \) 2>/dev/null)

    if [[ $mismatches -eq 0 ]]; then
        echo "   Permission check ($label): all paths under $root_path match (dirs 755, files $expected_file_mode)."
    else
        warn -p "Permission check ($label): $mismatches path(s) had unexpected modes under $root_path."
    fi
    return 0
}

# Executes a given subcommand for a list of URIs.
# @param $1 - The name of the function to call (e.g., "pull", "module").
# @param $@ - The list of URIs to process.
handle_subcommand() {
    local cmd="$1"
    shift
    for URI in "$@";
    do
        local bold_uri; bold_uri="\e[1m${URI}\e[0m"
        local bold_cmd; bold_cmd="\e[1m${cmd}\e[0m"
        echo -e "-> Processing URI ${bold_uri} with subcommand ${bold_cmd}"
        if ! "$cmd" "$URI"; then
            warn -p "Error executing command '$cmd' for URI: $URI"
            exit 1
        fi
    done
    return 0
}

# Copies the central 'repos' directory to the user's personal space if needed.
ensure_appinfo_dir() {
    if [[ "$personal" -eq 1 && ! -d "$HOME/container-apps/repos" ]]; then
        mkdir -p "$HOME/container-apps" || {
            warn -p "Error: Failed to create directory $HOME/container-apps"
            return 1
        }
        if [[ -d "$AppInfo_DIR" ]];
        then
            cp -r "$AppInfo_DIR" "$HOME/container-apps/" || {
                warn -p "Error: Failed to copy $AppInfo_DIR to $HOME/container-apps/"
                return 1
            }
        else
            warn -p "Error: Source directory $AppInfo_DIR does not exist"
            return 1
        fi
    fi
}

# Ensures an application info file exists, creating it if necessary.
# @param $1 - The container URI.
ensure_appinfo_file() {
    local URI="$1"
    if [[ -z "$URI" ]];
    then
        warn -p "Error: URI parameter is missing."
        return 1
    fi
    local app
    app=$(uri2app "$URI") || {
        warn -p "Error: Failed to extract app name from URI: $URI"
        return 1
    }
    local target_path
    if [[ ! -f "$HOME/container-apps/repos/$app" && ! -f "$AppInfo_DIR/$app" ]]; then
    	if [[ "$personal" -eq 1 ]];
    	then
        	target_path="$HOME/container-apps/repos/$app"
    	else
        	target_path="$AppInfo_DIR/$app"
    	fi
    	create_appinfo_file "$app" "$target_path" || {
        	warn -p "Error: Failed to create appinfo file for $app at $target_path"
        	return 1
    	}
    else
    	echo "   App info file already exists for '$app', skipping creation."
    fi
}

get_appinfo_file() {
    local app="$1"
    local path
    local search_paths=()

    if [[ $personal -eq 1 ]]; then
        search_paths+=("$HOME/container-apps/repos")
    fi
    search_paths+=("$AppInfo_DIR")

    for path in "${search_paths[@]}"; do
        if [[ -f "$path/$app" ]]; then
            echo "$path/$app"
            return 0
        fi
    done

    return 1
}


###############################################################################
#  URI TO NAME/VERSION/MODULE CONVERTERS
###############################################################################

# Converts a URI to a Singularity image filename.
# @param $1 - The container URI or local file path.
# @echo The resulting image filename (e.g., quay.io_biocontainers_vcftools:0.1.17--pl5321h077b44d_0.sif).
uri2imgname() {
	local uri="$1"
    if [[ -f "$uri" ]];
    then
        basename "$uri"
        return 0
    fi
	local file=""
	file="${uri#*://}"         # Drop protocol prefix
	file="${file//\//_}.sif"   # Replace slashes with underscores and add .sif
	echo "$file"
}

# Converts a URI to a modulefile path (app/version.lua).
# @param $1 - The container URI.
# @echo The resulting modulefile path.
uri2modname() {
	local uri="$1"
	local app
    app=$(uri2app "$uri") || return 1
	local modver
    modver=$(uri2ver "$uri") || return 1
    if [[ "$MODULE_SYSTEM" == "tcl" ]];
    then
        echo "$app/$modver"
    else
	    echo "$app/$modver.lua"
    fi
}

# Retrieves the cached application name for a URI.
# @param $1 - The container URI.
# @echo The application name.
uri2app() {
    local cache_index=""
    cache_index=$(cache_index_for_uri "$1") || return 1
    echo "${CACHE_APPS[$cache_index]}"
}

# Retrieves the cached version for a URI.
# @param $1 - The container URI.
# @echo The version string.
uri2ver() {
    local cache_index=""
    cache_index=$(cache_index_for_uri "$1") || return 1
    echo "${CACHE_VERSIONS[$cache_index]}"
}

###############################################################################
#  CORE LOGIC: PULL, MODULE, EXEC
###############################################################################

# Pulls a container image from a remote URI.
# @param $1 - The remote container URI.
#
# Named `cmd_pull` (not `pull`) so it does not shadow any system
# command of the same name.  Subcommand dispatch translates the
# user-visible `pull` keyword into a call to `cmd_pull`.
cmd_pull() {
    local uri=$1
    local is_local_file=0
    # If the URI is a local file, do nothing.
    if [[ -f "$uri" ]];
    then
        is_local_file=1
    elif [[ "$uri" != *"://"* ]];
    then
        warn -p "Error: The specified local file does not exist: $uri"
        return 1
    fi

    if [[ $is_local_file -eq 1 ]];
    then
        echo "   Local image file detected. Leaving it in its original location: $uri"
        if [[ $update_repo -eq 1 ]]; then
            warn -p "Note: --update is ignored for local image files (no remote URI to record)."
        fi
        return 0
    fi

    local imgname; imgname=$(uri2imgname "$uri") || return 1
    local image_outdir
    if [[ $personal -eq 1 ]];
    then
        image_outdir="$PRIVATE_IMAGEDIR"
    else
        image_outdir="$PUBLIC_IMAGEDIR"
    fi

    local target_image_path="${image_outdir}/${imgname}"

    if [[ -e "$target_image_path" && $force -eq 0 ]];
    then
        echo "   Image already exists: ${target_image_path}. Skipping."
        return 0
    fi

    # Pull the image and set its permissions to 644 (read-only for others).
    echo -e "   \e[1mPulling Singularity image...\e[0m"
    if ! "$CONTAINER_RUNTIME" pull --force "$target_image_path" "$uri"; then
        warn -p "Error: Container pull failed for $uri"
        rm -f "$target_image_path"
        return 1
    fi
    chmod 644 "$target_image_path"
    ensure_dir_access "$image_outdir" || {
        warn -p "Error: Failed to set permissions on image directory '$image_outdir'"
        return 1
    }
    echo "   Pull complete."
    echo "   Container image is saved to: $target_image_path"
    # Confirm the image lands at 644 even when the container runtime
    # creates it with a tighter mode (some apptainer versions honor
    # umask while pulling).
    if [[ $personal -eq 0 ]]; then
        local actual_mode; actual_mode=$(get_mode "$target_image_path")
        if [[ "$actual_mode" != "644" ]]; then
            warn -p "Permission warning: image $target_image_path is $actual_mode (expected 644)"
        fi
    fi

    # --- RE-ADDED REPOSITORY UPDATE LOGIC ---
    if [[ $update_repo -eq 1 ]];
    then
        local app; app=$(uri2app "$uri") || return 1
        local version; version=$(uri2ver "$uri") || return 1
        local app_file
        if ! app_file=$(get_appinfo_file "$app"); then
            warn -p "Error: App file for '$app' not found. Please create it first."
            rm -f "$target_image_path"
            return 1
        fi
        if [[ ! -f "$app_file" ]]; then
            warn -p "Error: App file '$app_file' not found. Please create it first."
            # We don't want to leave a dangling image if the update fails
            rm -f "$target_image_path"
            return 1
        fi

        local repo_uri="$uri"
        # Create a temporary file to build the updated content
        local temp_file
        temp_file=$(mktemp "${app_file}.XXXXXX") || { warn -p "Failed to create temp file"; return 1; }

        # Rebuild the file:
        # 1. Copy all lines EXCEPT the existing version lines.
        # 2. Add the NEW version line at the top.
        # 3. Append all the OLD version lines back.
        {
            grep -v '^version(' "$app_file"
            echo "version(\"$version\", uri=\"$repo_uri\")"
            grep '^version(' "$app_file" | grep -Fv "version(\"$version\","
        } > "$temp_file"

        # Atomically replace the old file with the new one
        if mv "$temp_file" "$app_file"; then
            # mktemp creates files mode 600; restore the world-readable
            # 644 expected for shared metadata so users / other admins
            # don't lose read access after a version bump.
            chmod 644 "$app_file"
            echo "   Updated app info file: $app_file with new version $version"
        else
            warn -p "Error: Failed to update app info file '$app_file'."
            rm -f "$target_image_path"
            return 1
        fi
    fi
}

# Generates an Lmod modulefile for a container.
# @param $1 - The container URI.
#
# Named `cmd_module` (not `module`) so it does not shadow Lmod's /
# Environment Modules' shell function of the same name - which would
# break detect_container_runtime's `module avail` / `module load`
# calls.  Subcommand dispatch translates the user-visible `module`
# keyword into a call to `cmd_module`.
cmd_module() {
    local URI="$1"
    local module_outdir
    if [[ $personal -eq 1 ]];
    then
        module_outdir="$PRIVATE_MODULEDIR"
    else
        module_outdir="$MOD_OUTDIR"
    fi

    local modname; modname=$(uri2modname "$URI") || return 1
    local OUTFILE="${module_outdir}/${modname}"

    if [[ -f "$OUTFILE" && $force -eq 0 ]];
    then
        echo "   Modulefile already exists: $OUTFILE. Skipping."
        return 0
    fi

    # Ensure the directory exists and has 755 permissions
    ensure_dir_access "$(dirname "$OUTFILE")" || {
        warn -p "Error: Failed to create directory for '$OUTFILE'"
        exit 1
    }

    # This command substitution captures the output of print_modulefile
    local MODULE; MODULE=$(print_modulefile "$URI")
    if [[ -z "$MODULE" ]]; then
        warn -p "Error: Failed to render modulefile content for '$URI'"
        return 1
    fi

    # Write atomically via a sibling temp file so an interrupted write
    # cannot leave a partial modulefile that Lmod would still try to load.
    local tmpfile
    tmpfile=$(mktemp "${OUTFILE}.XXXXXX") || {
        warn -p "Error: Failed to create temp file next to '$OUTFILE'"
        return 1
    }
    if printf '%s\n' "$MODULE" > "$tmpfile" && mv "$tmpfile" "$OUTFILE"; then
        # Set permissions to 644 (read-only for others).
        chmod 644 "$OUTFILE"
        ensure_tree_access "${module_outdir}/$(uri2app "$URI")" 644
        echo "   Generated module: $OUTFILE"
        # In shared admin mode, sanity-check that every path under this
        # app's module tree has the right modes.  Skipped in personal
        # mode where the user owns everything anyway.
        if [[ $personal -eq 0 ]]; then
            verify_tree_perms "${module_outdir}/$(uri2app "$URI")" 644 "modulefile"
        fi
    else
        rm -f "$tmpfile"
        warn -p "Error: Failed to write to '$OUTFILE'"
        return 1
    fi
}

# Determines if a new modulefile should be generated or an old one repurposed.
# @param $1 - The container URI.
# @echo The content of the generated modulefile.
print_modulefile() {
    local uri="$1"
    if [[ "$MODULE_SYSTEM" == "tcl" ]];
    then
        echo "   Tcl module mode enabled. Generating a new module from template." >&2
        generate_new_modulefile "$uri"
        return $?
    fi

    if [[ -n "${BIND_PATH:-}" ]];
    then
        echo "   BIND_PATH is set. Generating a new module from template to include bind settings." >&2
        generate_new_modulefile "$uri"
        return $?
    fi

    local app; app=$(uri2app "$uri") || return 1
    local latest_modulefile; latest_modulefile=$(find_latest_modulefile "$app")

    if [[ -z "$latest_modulefile" ]];
    then
        echo "   No existing modulefile found for '$app'. Generating a new one." >&2
        generate_new_modulefile "$uri"
    else
        echo "   Found existing modulefile: $latest_modulefile. Repurposing it for new version." >&2
        repurpose_old_modulefile "$uri" "$latest_modulefile"
    fi
    return $?
}

# Finds the most recently modified modulefile for a given application.
# @param $1 - The application name.
# @echo The path to the latest modulefile, or empty string if none found.
find_latest_modulefile() {
    local app="$1"
    local latest_file=""
    local latest_time=0
    local current_time=0
    local MOD_EXISTING_DIRS=()

    if [[ $personal -eq 1 ]];
    then
        MOD_EXISTING_DIRS=("$HOME/privatemodules" "$MOD_EXISTING_DIR")
    else
        MOD_EXISTING_DIRS=("$MOD_EXISTING_DIR")
    fi

    for dir in "${MOD_EXISTING_DIRS[@]}";
    do
        # Skip if directory is empty or doesn't exist.
        if [[ -z "$dir" || ! -d "$dir/$app" ]];
        then
            continue
        fi
        # Loop through all .lua files and find the newest one.
        for f in "$dir/$app/"*.lua;
        do
            [[ -e "$f" ]] || continue
            current_time=$(get_mtime "$f")
            if (( current_time > latest_time ));
            then
                latest_time=$current_time
                latest_file="$f"
            fi
        done
    done
    echo "$latest_file"
}

# Generates a new modulefile from the base template.
# @param $1 - The container URI.
# @echo The content of the new modulefile.
generate_new_modulefile() {
    local uri="$1"
    local exec_outdir
    if [[ $personal -eq 1 ]];
    then
        exec_outdir="${PRIVATE_EXECUTABLE_DIR/#\$HOME/$HOME}"
    else
        exec_outdir="$PUBLIC_EXECUTABLE_DIR"
    fi

    local image; image=$(uri2imgname "$uri") || return 1
    local app; app=$(uri2app "$uri") || return 1
    local ver; ver=$(uri2ver "$uri") || return 1
    local homepage=""
    local description=""
    read_home_description "$app"

    local registry=""
    local registry_url=""
    case "$uri" in
        *"biocontainers"*)
            registry="BioContainers"
            registry_url="https://biocontainers.pro/tools/$app"
            ;;
        *"nvcr.io/"*)
            registry="NVIDIA NGC"
            local ngc_repo=""
            ngc_repo=$(echo "$uri" | sed -E 's|^[a-z]+://nvcr\.io/([^:]*):.*|\1|')
            registry_url="https://catalog.ngc.nvidia.com/orgs/${ngc_repo}"
            ;;
        *"ghcr.io/"*)
            registry="GitHub Container Registry"
            local ghcr_repo=""
            ghcr_repo=$(echo "$uri" | sed -E 's|^[a-z]+://ghcr\.io/([^:]*):.*|\1|')
            registry_url="https://ghcr.io/${ghcr_repo}"
            ;;
        *"quay.io/"*)
            registry="Quay.io"
            local quay_repo=""
            quay_repo=$(echo "$uri" | sed -E 's|^[a-z]+://quay\.io/([^:]*):.*|\1|')
            registry_url="https://quay.io/repository/${quay_repo}"
            ;;
        *)
            registry="DockerHub"
            local docker_repo=""
            docker_repo=$(echo "$uri" | sed -E 's|^[a-z]+://([^:]*):.*|\1|')
            registry_url="https://hub.docker.com/r/${docker_repo}"
            ;;
    esac

    local template_file
    if [[ "$MODULE_SYSTEM" == "tcl" ]];
    then
        template_file="${TEMPLATE_DIR}/module_template.tcl"
    else
        template_file="${TEMPLATE_DIR}/module_template.lua"
    fi
    if [[ ! -f "$template_file" ]]; then
        warn -p "Error: Template file '$template_file' not found."
        return 1
    fi

    # Escape all variables before substituting them into the template
    local esc_desc; esc_desc=$(sedi_escape "$description")
    local esc_reg; esc_reg=$(sedi_escape "$registry")
    local esc_reg_url; esc_reg_url=$(sedi_escape "$registry_url")
    local esc_homepage; esc_homepage=$(sedi_escape "$homepage")
    local esc_image; esc_image=$(sedi_escape "$image")
    local esc_uri; esc_uri=$(sedi_escape "$uri")
    local esc_ver; esc_ver=$(sedi_escape "$ver")
    local esc_exec_dir; esc_exec_dir=$(sedi_escape "$exec_outdir")
    local esc_app; esc_app=$(sedi_escape "$app")
    local esc_bind; esc_bind=$(sedi_escape "${BIND_PATH:-}")

    local bind_env_var="${BIND_ENV_VAR:-}"
    if [[ -z "$bind_env_var" ]]; then
        case "${RUNTIME_MODULE:-${CONTAINER_RUNTIME_FLAVOR:-${CONTAINER_RUNTIME:-}}}" in
            singularity) bind_env_var="SINGULARITY_BIND" ;;
            apptainer) bind_env_var="APPTAINER_BIND" ;;
            *) bind_env_var="APPTAINER_BIND" ;;
        esac
    fi
    local esc_bind_env_var; esc_bind_env_var=$(sedi_escape "$bind_env_var")

    # Render the bind block conditionally so users without a configured
    # BIND_PATH do not get a hardcoded site-specific path baked into modules.
    local bind_lua_block=""
    local bind_tcl_block=""
    if [[ -n "${BIND_PATH:-}" ]]; then
        bind_lua_block="prepend_path{\"${esc_bind_env_var}\",\"${esc_bind}\",delim=\",\"}"
        bind_tcl_block="prepend-path --delim=\",\" ${esc_bind_env_var} \"${esc_bind}\""
    fi

    # Render the runtime-dependency block only when there is a real
    # module to depend on.  Sites where the container runtime is just
    # a system binary (e.g. Apptainer with no Lmod entry) leave this
    # empty so generated modulefiles do not fail to load.
    local runtime_depends_lua=""
    local runtime_depends_tcl=""
    if [[ -n "${RUNTIME_MODULE:-}" ]]; then
        local esc_rt; esc_rt=$(sedi_escape "$RUNTIME_MODULE")
        runtime_depends_lua="depends_on(\"${esc_rt}\")"
        runtime_depends_tcl="if { [info commands depends-on] ne \"\" } { depends-on ${esc_rt} } else { if { ![is-loaded ${esc_rt}] } { module load ${esc_rt} } }"
    fi

    # Substitute placeholders in the template using the escaped variables
    sed -e "s|\${DESCRIPTION}|$esc_desc|g" \
        -e "s|\${REGISTRY}|$esc_reg|g" \
        -e "s|\${REGISTRY_URL}|$esc_reg_url|g" \
        -e "s|\${HOMEPAGE}|$esc_homepage|g" \
        -e "s|\${IMAGE}|$esc_image|g" \
        -e "s|\${URI}|$esc_uri|g" \
        -e "s|\${VERSION}|$esc_ver|g" \
        -e "s|\${EXECUTABLE_DIR}|$esc_exec_dir|g" \
        -e "s|\${APP}|$esc_app|g" \
        -e "s|\${RUNTIME_DEPENDS_LUA}|$runtime_depends_lua|g" \
        -e "s|\${RUNTIME_DEPENDS_TCL}|$runtime_depends_tcl|g" \
        -e "s|\${BIND_LUA}|$bind_lua_block|g" \
        -e "s|\${BIND_TCL}|$bind_tcl_block|g" \
        "$template_file"
}

# Updates an existing modulefile for a new version of a container.
# @param $1 - The container URI of the new version.
# @param $2 - The file path to the old modulefile to use as a template.
# @echo The content of the updated modulefile.
repurpose_old_modulefile() {
    local uri="$1"
    local template="$2"
    local image; image=$(uri2imgname "$uri") || return 1
    local ver; ver=$(uri2ver "$uri") || return 1

    # Use awk to replace version, image, and URI strings in the old modulefile
    local buf; buf=$(awk -v ver="$ver" -v image="$image" -v uri="$uri" '
        /^[[:blank:]]*whatis.*Version:/ { $0 = "whatis(\"Version: " ver "\")" }
        /^[[:blank:]]*local[[:blank:]]+version[[:blank:]]*=/ { $0 = "local version = \"" ver "\"" }
        /^[[:blank:]]*local[[:blank:]]+image[[:blank:]]*=/ { $0 = "local image = \"" image "\"" }
        /^[[:blank:]]*local[[:blank:]]+uri[[:blank:]]*=/ { $0 = "local uri = \"" uri "\"" }
        /^[[:blank:]]*local[[:blank:]]+modroot[[:blank:]]*=/ { sub(/\.\. ".*"/, ".. \"" ver "\"") }
        { print }
    ' < "$template")

    if [[ $? -ne 0 || -z "$buf" ]]; then
        warn -p "Error: Failed to repurpose template '$template' for '$uri'"
        generate_new_modulefile "$uri"
        return $?
    fi
    echo "$buf"
}

# Generates executable wrapper scripts for programs inside a container.
# @param $1 - The container URI.
#
# Named `cmd_exec` (not `exec`) so it does not shadow bash's `exec`
# builtin.  Subcommand dispatch translates the user-visible `exec`
# keyword into a call to `cmd_exec`.
cmd_exec() {
    local uri="$1"
    local app; app=$(uri2app "$uri") || return 1
    local ver; ver=$(uri2ver "$uri") || return 1

    local image_dir_for_wrapper image_name_for_wrapper
    if [[ -f "$uri" ]];
    then
        local absolute_path; absolute_path="$(realpath "$uri")"
        image_dir_for_wrapper="$(dirname "$absolute_path")"
        image_name_for_wrapper="$(basename "$absolute_path")"
    else
        if [[ $personal -eq 1 ]];
        then
            image_dir_for_wrapper="$PRIVATE_IMAGEDIR"
        else
            image_dir_for_wrapper="$PUBLIC_IMAGEDIR"
        fi
        image_name_for_wrapper=$(uri2imgname "$uri") || return 1
    fi

    local exec_array=()
    if ! mapfile -t exec_array < <(parse_exec "$app"); then
        warn -p "No executables are defined for '$app'. Skipping exec generation."
        return 0
    fi

    local exec_outdir
    if [[ $personal -eq 1 ]];
    then
        exec_outdir="$PRIVATE_EXECUTABLE_DIR"
    else
        exec_outdir="$EXEC_OUTDIR"
    fi

    local AppTool_dir="${exec_outdir}/${app}/${ver}/bin"
    if [[ -d "$AppTool_dir" && $force -eq 0 ]];
    then
        warn -p "Output directory $AppTool_dir already exists. Skipping."
        return 0
    fi

    if [[ -d "$AppTool_dir" && $force -eq 1 ]];
    then
        echo "   Force option enabled, removing existing directory $AppTool_dir"
        rm -rf "$AppTool_dir" || { warn -p "Failed to remove dir $AppTool_dir"; exit 1; }
    fi
    ensure_dir_access "$AppTool_dir" || { warn -p "Failed to create dir $AppTool_dir"; exit 1; }

    echo "   Generating executables for $app version $ver..."
    for command_exec in "${exec_array[@]}";
    do
        if confirm_exec_exists "$command_exec" "${image_dir_for_wrapper}/${image_name_for_wrapper}";
        then
            if generate_executable "$app" "$ver" "$command_exec" "$image_dir_for_wrapper" "$image_name_for_wrapper" "$AppTool_dir";
            then
                echo "     -> Successfully generated: $command_exec"
            else
                warn -p "     -> Error: Failed to generate executable: $command_exec"
            fi
        else
            warn -p "     -> Warning: Executable not found in container: $command_exec"
        fi
    done

    ensure_tree_access "${exec_outdir}/${app}" 755

    echo "   Executables generated in: ${exec_outdir}/${app}/${ver}"
    # Sanity-check the wrapper tree in shared admin mode.  Wrappers are
    # all executable, so files and dirs both want 755.
    if [[ $personal -eq 0 ]]; then
        verify_tree_perms "${exec_outdir}/${app}" 755 "wrappers"
    fi
}

# Checks if a given command exists inside the container.
# @param $1 - The command name to check.
# @param $2 - The full path to the container image file.
# @return 0 if it exists, 1 otherwise.
confirm_exec_exists() {
    local exec_cmd="$1"
    local image_path="$2"
    # Use POSIX `command -v` via /bin/sh - works in distroless containers
    # where `which` is not installed.  Fall back to `which` if the shell
    # form fails for any reason.
    if "$CONTAINER_RUNTIME" exec "$image_path" sh -c "command -v $(printf %q "$exec_cmd")" &> /dev/null; then
        return 0
    fi
    if "$CONTAINER_RUNTIME" exec "$image_path" which "$exec_cmd" &> /dev/null; then
        return 0
    fi
    return 1
}

# Creates a single executable wrapper script.
# @param ... - app, version, command, image_dir, image_name, AppTool_dir
# @return 0 on success, 1 on failure.
generate_executable() {
    local app=$1 version=$2 command=$3 image_dir=$4 image_name=$5 AppTool_dir=$6
    local executable="${AppTool_dir}/${command}"

    if [[ -z "$app" || -z "$version" || -z "$command" || -z "$image_dir" || -z "$image_name" || -z "$AppTool_dir" ]];
    then
        warn -p "Error: Missing arguments for generate_executable"
        return 1
    fi

    ensure_dir_access "$(dirname "$executable")" || return 1

    # Build the runtime-bootstrap block.  If a Lmod entry for the
    # runtime exists on this host (we resolved this in RUNTIME_MODULE
    # at startup), the wrapper falls back to `module load <name>`
    # when the runtime binary is missing from PATH.  On hosts where
    # the runtime is just a system binary with no module entry
    # (RUNTIME_MODULE empty), we skip the module-load step entirely
    # and just print a clear error - calling `module load` against a
    # non-existent module would itself error and confuse the user.
    local runtime_bootstrap
    if [[ -n "${RUNTIME_MODULE:-}" ]]; then
        read -r -d '' runtime_bootstrap <<EOF || true
# Load the container runtime if it is not already loaded.
if ! command -v "\$RUNTIME" &> /dev/null; then
    if command -v module &> /dev/null; then
        module load "$RUNTIME_MODULE" || { echo "Failed to load $RUNTIME_MODULE module"; exit 1; }
    fi
fi
EOF
    else
        read -r -d '' runtime_bootstrap <<'EOF' || true
# This wrapper was generated on a host where the container runtime
# is provided as a system binary (no Lmod entry).  We do not attempt
# `module load` here because there is no module by that name to load.
EOF
    fi

    # Create the wrapper script with a heredoc
cat <<EOF >"$executable"
#!/usr/bin/env bash
# Wrapper script for '$command' from container '$image_name'

# Set variables
VER="$version"
PKG="$app"
PROGRAM="$command"
IMAGE_DIR="$image_dir"
IMAGE="$image_name"
RUNTIME="$CONTAINER_RUNTIME"

$runtime_bootstrap

if ! command -v "\$RUNTIME" &> /dev/null; then
    echo "Failed to find container runtime: \$RUNTIME"
    exit 1
fi

# Determine GPU flags for the container runtime.  --nv (NVIDIA) and --rocm
# (AMD) are mutually exclusive; prefer --nv when both runtimes are detected.
OPTIONS=()
if command -v nvidia-smi &> /dev/null && nvidia-smi -L &> /dev/null; then
    OPTIONS+=("--nv")
elif command -v rocm-smi &> /dev/null && rocm-smi -L &> /dev/null; then
    OPTIONS+=("--rocm")
fi

# Add any extra runtime options in the variable "RUNTIME_OPTIONS"
if [ "\${RUNTIME_OPTIONS}" != "" ]
then
  IFS=' ' read -a ADDR <<< "\${RUNTIME_OPTIONS}"
  for i in "\${ADDR[@]}"; do
    OPTIONS+=("\${i}")
  done
fi

# Run the container command
exec "\$RUNTIME" run "\${OPTIONS[@]}" "\$IMAGE_DIR/\$IMAGE" "\$PROGRAM" "\$@"
EOF

    # Set permissions to 755 (executable for all).
    chmod 755 "$executable"
    if [[ $? -ne 0 ]]; then
        warn -p "Error: Failed to set permissions for wrapper $command"
        return 1
    fi
}

###############################################################################
#  APP INFO AND EXECUTABLE PARSING FROM REPO FILES
###############################################################################

# Creates a new application info file based on user input.
# @param $1 - The application name.
# @param $2 - The full path to the new app info file.
create_appinfo_file() {
    local app=$1
    local localappinfo=$2
    echo "'$app' not found in application info database."
    echo "Let's create a new entry..."
    local description homepage programs
    read -r -p "Enter a simple description of the application: " description
    read -r -p "Enter the application's homepage URL: " homepage
    read -r -p "Enter the available programs (comma-separated): " programs
    mkdir -p "$(dirname "$localappinfo")"
    {
        echo "Description: $description"
        echo "Home Page: $homepage"
        echo "Programs: $programs"
    } > "$localappinfo"
    # Make sure other admins (and downstream tooling) can read the
    # metadata regardless of the calling shell's umask.
    chmod 644 "$localappinfo"
}

# Parses the 'Description' and 'Home Page' from an app info file.
read_home_description() {
    local app="$1"
    local app_file=""

    if ! app_file=$(get_appinfo_file "$app"); then
        return 1
    fi

    if [[ -f "$app_file" ]]; then
        description=$(sed -n 's/^Description: //p' "$app_file" | head -n 1)
        homepage=$(sed -n 's/^Home Page: //p' "$app_file" | head -n 1)
    fi
}

# Parses the 'Programs' list from an app info file.
# @echo A space-separated list of executable names.
parse_exec() {
    local app="$1"
    local app_file
    app_file=$(get_appinfo_file "$app") || app_file=""

    if [[ ! -f "$app_file" ]]; then
        warn -p "Error: Application file '$app_file' not found."
        return 1
    fi

    local executables
    executables=$(grep -m1 "^Programs:" "$app_file" | sed 's/^Programs: //')
    if [[ -z "$executables" ]];
    then
        return 1
    fi

    local entry
    IFS=',' read -r -a arr <<< "$executables"
    for entry in "${arr[@]}"; do
        entry="${entry#"${entry%%[![:space:]]*}"}"
        entry="${entry%"${entry##*[![:space:]]}"}"
        [[ -n "$entry" ]] && echo "$entry"
    done
}

###############################################################################
#  JUPYTER KERNEL CREATION
###############################################################################

# Generates a Jupyter kernel for the container.
# @param $1 - The container URI.
jupyter() {
    local uri=$1
    local app; app=$(uri2app "$uri") || return 1
    local ver; ver=$(uri2ver "$uri") || return 1
    local image; image=$(uri2imgname "$uri") || return 1
    local kernel_name="${app}-${ver}"
    local kernel_dir
    local image_path

    if [[ $personal -eq 1 ]];
    then
        kernel_dir="$HOME/.local/share/jupyter/kernels/$kernel_name"
    else
        kernel_dir="${JUPYTER_OUTDIR}/${kernel_name}"
    fi

    if [[ -f "$uri" ]];
    then
        image_path="$(realpath "$uri")"
    else
        local image_outdir
        if [[ $personal -eq 1 ]];
        then
            image_outdir="$PRIVATE_IMAGEDIR"
        else
            image_outdir="$PUBLIC_IMAGEDIR"
        fi
        image_path="${image_outdir}/${image}"
    fi

    # Check for ipykernel dependency inside the container
    if ! "$CONTAINER_RUNTIME" exec "$image_path" python -c "import ipykernel" &> /dev/null; then
        MSG=( "The dependency 'ipykernel' was not detected in ${image}." "" "Please add it to your container definition:" "" "   pip install ipython ipykernel" )
        boxify_text "${MSG[@]}"
        exit 1
    fi

    # Create kernel directory and kernel.json file
    if [[ ! -d "$kernel_dir" ]]; then
        ensure_dir_access "$kernel_dir" || {
            warn -p "Error: Failed to create kernel directory '$kernel_dir'"
            return 1
        }
        cp "$SCRIPT_TOP_DIR/jupyter_kernel.json" "${kernel_dir}/kernel.json"

        local exec_outdir
        if [[ $personal -eq 1 ]];
        then
            exec_outdir="${PRIVATE_EXECUTABLE_DIR/#\$HOME/$HOME}"
        else
            exec_outdir="$PUBLIC_EXECUTABLE_DIR"
        fi

        local AppTool_dir="${exec_outdir}/${app}/${ver}/bin"
        local esc_apptool_dir; esc_apptool_dir=$(sedi_escape "$AppTool_dir")
        local esc_app; esc_app=$(sedi_escape "$app")
        local esc_ver; esc_ver=$(sedi_escape "$ver")

        local kernel_tmp
        kernel_tmp=$(mktemp "${kernel_dir}/kernel.json.XXXXXX") || {
            warn -p "Error: Failed to create temporary kernel file"
            return 1
        }
        sed -e "s|APPDIR|$esc_apptool_dir|g" \
            -e "s|APP|$esc_app|g" \
            -e "s|VERSION|$esc_ver|g" \
            "${kernel_dir}/kernel.json" > "$kernel_tmp"
        mv "$kernel_tmp" "${kernel_dir}/kernel.json"
        ensure_tree_access "$kernel_dir" 644
    else
        echo "   Kernel already exists: $kernel_dir. Skipping."
    fi
    echo "   Jupyter kernel created: $kernel_name"
    MSG=( "You can now launch Jupyter and select the kernel:" "" "   $app $ver" )
    boxify_text "${MSG[@]}"
}

###############################################################################
#  MAIN SCRIPT LOGIC
###############################################################################

# --- Default Configuration Options ---
force=0
personal=0
jupyter=0
write_to_profile_dirs=0
update_repo=0
PROFILE=""
SCRIPT_TOP_DIR="$(realpath "${BASH_SOURCE[0]}" | xargs dirname)"
TEMPLATE_DIR="$SCRIPT_TOP_DIR/templates"
AppInfo_DIR="${SCRIPT_TOP_DIR}/repos"
PROFILEROOT="${SCRIPT_TOP_DIR}/profiles"
OUTDIR_DEF="."
OUTDIR="${OUTDIR:-$OUTDIR_DEF}"
PRIVATE_EXECUTABLE_DIR="$HOME/container-apps/tools"
PRIVATE_MODULEDIR="$HOME/privatemodules"
PRIVATE_IMAGEDIR="$HOME/container-apps/images"
PROFILEHOMEDIR="$HOME/container-apps/profiles"

# These are populated by profile files.  Initialize them so `set -u`
# does not abort when running in personal mode without a profile.
MOD_EXISTING_DIR=""
MOD_EXISTING_DIR_DEF=""
PUBLIC_IMAGEDIR=""
PUBLIC_EXECUTABLE_DIR=""
BIND_PATH=""
# RUNTIME_MODULE is intentionally NOT initialized here.  We detect
# "user did not set it" later via ${RUNTIME_MODULE+x} so that
# profiles can either override the auto-detection or set
# RUNTIME_MODULE="" to explicitly disable the depends_on line.

# --- Argument and Subcommand Parsing ---
SUBCOMMAND="${1:-}"
if [[ -z "$SUBCOMMAND" || "$SUBCOMMAND" == "-h" || "$SUBCOMMAND" == "--help" ]];
then
    help_message
    exit 0
fi
if [[ "$SUBCOMMAND" == "-v" || "$SUBCOMMAND" == "--version" ]];
then
    echo "$PROGNAME $VERSION"
    exit 0
fi
if [[ "$SUBCOMMAND" == "-l" || "$SUBCOMMAND" == "--list" ]];
then
    list_profiles
    exit 0
fi
shift # Move past the subcommand

declare -a ARGV
while (($#));
do
    case $1 in
        --profile) shift; PROFILE="$1" ;;
        -c|--container-app) shift; CONTAINER_APPS="$1" ;;
        -d|--dir|--directory) shift; OUTDIR="$1" ;;
        -f|--force) force=1 ;;
        -m|--module-dir|--module-directory) shift; MOD_EXISTING_DIR="$1" ;;
        --write-to-profile-dirs|--write-to-profile-directories) write_to_profile_dirs=1 ;;
        -s|--module-system) shift; MODULE_SYSTEM="$1" ;;
        -u|--update) update_repo=1 ;;
        -p|--personal) personal=1 ;;
        -t|--tcl) MODULE_SYSTEM="tcl" ;;
        -j|--jupyter) jupyter=1 ;;
        --) shift; break ;;
        -*) warn -p "Unknown option: $1"; help_message; exit 1 ;;
        *) ARGV+=("$1") ;;
    esac
    shift
done
set -- "${ARGV[@]}" # Set positional parameters to remaining arguments

MOD_OUTDIR="${OUTDIR}/incomplete"
EXEC_OUTDIR="${OUTDIR}/executables"
JUPYTER_OUTDIR="${OUTDIR}/kernels"

if [[ "$MODULE_SYSTEM" != "lmod" && "$MODULE_SYSTEM" != "tcl" ]];
then
    warn -p "Error: Unsupported module system '$MODULE_SYSTEM'. Use 'lmod' or 'tcl'."
    exit 1
fi

for container_app in ${CONTAINER_APPS}
do
    if [[ "${container_app}" != "singularity" && "${container_app}" != "apptainer" ]];
    then
        warn -p "Error: Unsupported container application '${container_app}'. Use 'singularity' or 'apptainer'."
        exit 1
    fi
done

if [[ $# -eq 0 ]]; then
    warn -p "Error: At least one container URI or image path is required."
    help_message >&2
    exit 1
fi

if [[ "${PROFILE}" = "" && ${write_to_profile_dirs} -eq 1 ]];
then
    warn -p "Error: the \"--write-to-profile-dirs\" option requires the \"-p|--profile profile\" option."
    exit 1
fi

detect_container_runtime || exit 1

# --- Profile Loading ---
if [[ -n "$PROFILE" ]];
then
    if [[ -f "${PROFILEHOMEDIR}/$PROFILE" ]]; then
        echo "Loading personal profile: $PROFILE"
        source "${PROFILEHOMEDIR}/$PROFILE"
    elif [[ -f "${PROFILEROOT}/$PROFILE" ]];
    then
        echo "Loading system profile: $PROFILE"
        source "${PROFILEROOT}/$PROFILE"
    else
        warn -p "Error: Profile '$PROFILE' not found."
        exit 1
    fi
    if [[ ${write_to_profile_dirs} -eq 1 ]];
    then
        # changed the output dirs to the ones provided in the current profile
        if [[ "${MOD_EXISTING_DIR_DEF}" != "" ]];
        then
            MOD_OUTDIR="${MOD_EXISTING_DIR_DEF}"
        else
            warn -p "Error: MOD_EXISTING_DIR_DEF variable setting not found in the profile '$PROFILE'"
            exit 1
        fi
        if [[ "${PUBLIC_EXECUTABLE_DIR}" != "" ]];
        then
            EXEC_OUTDIR="${PUBLIC_EXECUTABLE_DIR}"
        else
            warn -p "Error: PUBLIC_EXECUTABLE_DIR variable setting not found in the profile '$PROFILE'"
            exit 1
        fi
    fi
else
    echo "No profile specified. Running in personal mode."
    personal=1
fi

# Set default if not defined in profile
MOD_EXISTING_DIR="${MOD_EXISTING_DIR:-${MOD_EXISTING_DIR_DEF:-}}"

# Resolve the Lmod / Environment Modules name to record as the
# runtime dependency in generated modulefiles.
#
#   - If the profile (or environment) set RUNTIME_MODULE explicitly
#     (including to ""), honor that choice.
#   - Otherwise auto-detect: if a module by the runtime's name is
#     loadable, depend on it; if not (e.g. Apptainer is just a system
#     binary with no module entry), emit no dependency line.
if [[ -z "${RUNTIME_MODULE+x}" ]]; then
    if module_is_available "$CONTAINER_MODULE_NAME"; then
        RUNTIME_MODULE="$CONTAINER_MODULE_NAME"
    else
        RUNTIME_MODULE=""
    fi
fi

# --- Initialization ---
echo "Initializing..."
ensure_appinfo_dir

# Only prompt for missing app metadata when the subcommand will actually
# consume it.  A plain `pull` (without --update) just downloads the
# image and never reads Description / Home Page / Programs, so we skip
# the interactive prompt and let users pull containers without having
# to commit to writing a metadata entry up front.  `pull -u` still
# needs the file to record the new version() line, and `module`,
# `exec`, and `pipe` all consume metadata directly.
needs_appinfo=1
if [[ "$SUBCOMMAND" == "pull" && $update_repo -eq 0 ]]; then
    needs_appinfo=0
fi

for URI in "$@"; do
    _ensure_uri_details_cached "$URI" || { warn -p "Could not get app details for $URI"; exit 1; }
    if [[ $needs_appinfo -eq 1 ]]; then
        ensure_appinfo_file "$URI"
    fi
done

# Create output directories
if [[ $personal -eq 1 ]];
then
    create_dir "$PRIVATE_EXECUTABLE_DIR" "Created personal executable directory"
    create_dir "$PRIVATE_MODULEDIR" "Created personal module directory"
    create_dir "$PRIVATE_IMAGEDIR" "Created personal image directory"
else
    create_dir "$EXEC_OUTDIR" "Created public executable directory"
    create_dir "$MOD_OUTDIR" "Created public module directory"
    if [[ -n "${PUBLIC_IMAGEDIR:-}" ]]; then create_dir "$PUBLIC_IMAGEDIR" "Created public image directory"; fi
fi

# --- Main Subcommand Execution ---
case "$SUBCOMMAND" in
    pull)   handle_subcommand cmd_pull "$@" ;;
    module) handle_subcommand cmd_module "$@" ;;
    exec)   handle_subcommand cmd_exec "$@" ;;
    pipe)
        handle_subcommand cmd_pull "$@"
        handle_subcommand cmd_module "$@"
        handle_subcommand cmd_exec "$@"
        ;;
    *)
        warn -p "Invalid subcommand: $SUBCOMMAND"
        help_message >&2
        exit 1 ;;
esac

# --- Final User Messages ---
if [[ "$SUBCOMMAND" == "module" || "$SUBCOMMAND" == "pipe" ]];
then
    for URI in "$@"; do
        app=$(uri2app "$URI") || continue
        ver=$(uri2ver "$URI") || continue
        modname=$(uri2modname "$URI") || continue
        if [[ $personal -eq 1 ]];
        then
            MSG=( "To use this module, load:" "" "    module load use.own" "    module load $app/$ver" )
        else
            MSG=( "To use this module, load:" "" "    module use $MOD_OUTDIR" "    module load $app/$ver" )
        fi
        boxify_text "${MSG[@]}"
    done
fi

if [[ $jupyter -eq 1 ]]; then
    for URI in "$@";
    do
        echo "Generating Jupyter kernel for $URI"
        if ! jupyter "$URI"; then
            warn -p "Error creating Jupyter kernel for $URI"
        fi
    done
fi

echo -e "\e[1mScript finished successfully.\e[0m"
